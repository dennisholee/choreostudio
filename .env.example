# ChoreoStudio environment variables
# Copy to .env and fill in values — never commit .env

# Database
DATABASE_URL=postgres://choreostudio:choreostudio_dev@localhost:5432/choreostudio

# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Frontend (Vite — prefix with VITE_)
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000/ws

# Auth (M4 — fill in when implementing SSO)
# SAML_ENTRY_POINT=
# SAML_ISSUER=
# SAML_CERT=
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# SESSION_SECRET=
